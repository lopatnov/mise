# Copy this file to .env.prod and fill in the values before running in production.
# Never commit .env.prod to git.

# Public URL of the API — must be reachable from users' browsers.
# Examples:
#   http://123.45.67.89:3000       (bare IP)
#   https://api.mise.example.com   (domain with TLS termination upstream)
APP_URL=http://YOUR_SERVER_IP:3000

# JWT signing secret — must be long and random.
# Generate: openssl rand -hex 32
JWT_SECRET=replace_with_a_random_secret

# Token lifetime (optional, default: 7d)
JWT_EXPIRES_IN=7d
